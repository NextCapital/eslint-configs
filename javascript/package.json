{
  "name": "@nextcapital/eslint-config",
  "version": "1.0.0",
  "description": "ESLint config to enforce our styleguide",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./jest": "./jest/index.js",
    "./jest.js": "./jest/index.js",
    "./jsdoc": "./jsdoc/index.js",
    "./jsdoc.js": "./jsdoc/index.js",
    "./node": "./node/index.js",
    "./node.js": "./node/index.js",
    "./react": "./react/index.js",
    "./react.js": "./react/index.js",
    "./base/flat/*": "./base/flat/*.js",
    "./base/flat/*.js": "./base/flat/*.js",
    "./jest/flat/*": "./jest/flat/*.js",
    "./jest/flat/*.js": "./jest/flat/*.js",
    "./jsdoc/flat/*": "./jsdoc/flat/*.js",
    "./jsdoc/flat/*.js": "./jsdoc/flat/*.js",
    "./node/flat/*": "./node/flat/*.js",
    "./node/flat/*.js": "./node/flat/*.js",
    "./react/flat/*": "./react/flat/*.js",
    "./react/flat/*.js": "./react/flat/*.js"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">= 20.19.0",
    "npm": ">= 9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NextCapital/eslint-configs.git"
  },
  "author": {
    "name": "NextCapital Group",
    "url": "https://nextcapital.com"
  },
  "bugs": {
    "url": "https://github.com/NextCapital/eslint-configs/issues"
  },
  "homepage": "https://github.com/NextCapital/eslint-configs#readme",
  "scripts": {
    "autopublish": "auto-publish-package",
    "ci:local": "npm run lint",
    "inspect-config:base": "eslint --inspect-config --config=index.js",
    "inspect-config:jest": "eslint --inspect-config --config=jest/index.js",
    "inspect-config:jsdoc": "eslint --inspect-config --config=jsdoc/index.js",
    "inspect-config:node": "eslint --inspect-config --config=node/index.js",
    "inspect-config:react": "eslint --inspect-config --config=react/index.js",
    "lint": "eslint --config=internal.js --cache"
  },
  "peerDependencies": {
    "eslint": ">= 10",
    "eslint-plugin-import": "^2.30.0"
  },
  "dependencies": {
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "confusing-browser-globals": "^1.0.11",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0"
  },
  "devDependencies": {
    "auto-publish-package": "^2.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-import": "^2.32.0"
  },
  "overrides": {
    "minimatch@3.1.2": "3.1.3",
    "minimatch@9.0.5": "9.0.7",
    "eslint-plugin-import": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  }
}
